import javax.swing.*;
import java.awt.event.*;
import java.sql.*;

public class LoginFrame extends JFrame {
    JTextField userField;
    JPasswordField passField;

    public LoginFrame() {
        setTitle("Login");
        setSize(300,200);
        setLayout(null);

        JLabel u = new JLabel("Username:");
        u.setBounds(20,20,100,25);
        add(u);

        userField = new JTextField();
        userField.setBounds(120,20,120,25);
        add(userField);

        JLabel p = new JLabel("Password:");
        p.setBounds(20,60,100,25);
        add(p);

        passField = new JPasswordField();
        passField.setBounds(120,60,120,25);
        add(passField);

        JButton login = new JButton("Login");
        login.setBounds(100,100,80,30);
        add(login);

        login.addActionListener(e -> authenticate());

        setDefaultCloseOperation(EXIT_ON_CLOSE);
        setVisible(true);
    }

    void authenticate() {
        try {
            Connection con = DBConnection.getConnection();
            PreparedStatement ps = con.prepareStatement(
                "SELECT * FROM users WHERE username=? AND password=?"
            );
            ps.setString(1, userField.getText());
            ps.setString(2, new String(passField.getPassword()));

            ResultSet rs = ps.executeQuery();

            if(rs.next()) {
                JOptionPane.showMessageDialog(this, "Login Success");
                new QuizFrame(rs.getInt("user_id"));
                dispose();
            } else {
                JOptionPane.showMessageDialog(this, "Invalid Login");
            }
        } catch(Exception ex) {
            ex.printStackTrace();
        }
    }
}
